# NeuroScale Autopilot v2 — Environment Configuration
# Copy this file to .env and fill in your actual values

# ─── Qwen API Configuration ────────────────────────────────────────────────────
QWEN_API_KEY=your-dashscope-api-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_MAX=qwen3-max
QWEN_MODEL_PLUS=qwen-plus
QWEN_MODEL_TURBO=qwen-turbo
QWEN_MODEL_EMBEDDING=text-embedding-v3

# ─── Application Configuration ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# ─── Kubernetes Configuration ─────────────────────────────────────────────────
KUBECONFIG=/home/user/.kube/config
DRY_RUN=true
POLL_INTERVAL_SECONDS=30

# ─── Slack Integration (Optional) ──────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ─── Alibaba Cloud Configuration (Optional) ────────────────────────────────────
ALIBABA_ACCESS_KEY_ID=your-access-key-id
ALIBABA_ACCESS_KEY_SECRET=your-access-key-secret
ALIBABA_REGION_ID=cn-hangzhou

# ─── Trust Layer Configuration ─────────────────────────────────────────────────
TRUST_EXECUTE_THRESHOLD=90
TRUST_DRYRUN_THRESHOLD=70
TRUST_ESCALATION_TIMEOUT_SECONDS=300

# ─── Chaos Injection Configuration ─────────────────────────────────────────────
CHAOS_ENABLED=true
CHAOS_CLEANUP_TIMEOUT_SECONDS=60

# ─── Benchmarking Configuration ────────────────────────────────────────────────
BENCHMARK_RUNS=5
BENCHMARK_CLUSTER=default

# ─── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_TRUST_LAYER=true
ENABLE_QWEN3_MAX_THINKING=true
ENABLE_CHAOS_INJECTION=true
ENABLE_MCP_EXPANSION=true
ENABLE_COST_GOVERNOR=true
